DATABASE_URL="postgresql://postgres:g%2B_pSM%40f7ftsDUw@db.pdnjwjpshvjghwwuqljz.supabase.co:5432/postgres?schema=public&sslmode=require"

# NextAuth (Google OAuth):
# Create in Google Cloud Console -> OAuth 2.0 Client ID (Web application)
# This repo supports both naming styles below; prefer GOOGLE_CLIENT_ID/SECRET.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_GOOGLE_ID=""       # optional legacy alias
AUTH_GOOGLE_SECRET=""   # optional legacy alias

# NextAuth secret (generate your own):
NEXTAUTH_SECRET="replace-with-a-random-32+chars-secret"
AUTH_SECRET="" # optional legacy alias

# App URL (dev):
NEXTAUTH_URL="http://localhost:3000"

# Admin page protection (required for /admin):
ADMIN_PAGE_PASSWORD=""
# Optional override for admin cookie signing.
# If empty, NEXTAUTH_SECRET / AUTH_SECRET is used.
ADMIN_COOKIE_SECRET=""

# Stripe (test keys):
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
