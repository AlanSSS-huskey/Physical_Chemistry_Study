# You must create your own .env (do NOT commit it).
# Required for Prisma (PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/physchem?schema=public"

# NextAuth (Google OAuth):
# Create in Google Cloud Console -> OAuth 2.0 Client ID (Web application)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# NextAuth secret (generate your own):
AUTH_SECRET="replace-with-a-random-32+chars-secret"

# App URL (dev):
NEXTAUTH_URL="http://localhost:3000"

# Stripe (test keys):
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

